{
  "name": "luma-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "test": "jest",
    "test:all": "jest",
    "test:changed": "jest --onlyChanged --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:rls": "bun run test/rls/run-rls-checks.ts",
    "test:e2e:mobile": "maestro test e2e/maestro/flows/",
    "test:e2e:mobile:smoke": "maestro test e2e/maestro/flows/auth-login.yaml e2e/maestro/flows/tasks-create.yaml",
    "test:e2e:web": "playwright test --config=e2e/playwright/playwright.config.ts",
    "test:e2e:web:ui": "playwright test --config=e2e/playwright/playwright.config.ts --ui",
    "test:coverage:check": "bun run scripts/check-test-coverage.ts",
    "test:generate": "bun run scripts/generate-test.ts",
    "test:coverage:new-files": "bun run scripts/check-new-files-coverage.ts",
    "test:report": "jest --ci --coverage --json --outputFile=test-results/jest-results.json --reporters=default --reporters=jest-junit",
    "test:report:summary": "bun run scripts/generate-test-summary.ts",
    "test:report:all": "npm run test:report && npm run test:report:summary",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "mcp:n8n": "bunx n8n-mcp2.29.0"
  },
